# ── Bifrost ──────────────────────────────────
# Bifrost Gateway listens on port 8080 by default
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=info
LOG_STYLE=pretty

# ── Bifrost UI Auth ─────────────────────────
# Credentials for the Bifrost dashboard (configured via auth_config in config.json)
BIFROST_USERNAME=admin
BIFROST_PASSWORD=bifrost123

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_DB=otel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── OpenTelemetry ────────────────────────────
# These are used inside the container - the otel-collector runs on the
# Docker network as "otel-collector", so Bifrost uses that hostname.
OTEL_COLLECTOR_URL=http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# ── Headroom ────────────────────────────
# AI Context Compression Proxy
# Listens on port 8787 by default, routes through Bifrost
HEADROOM_PORT=8787
HEADROOM_LOG_LEVEL=info
HEADROOM_TELEMETRY=off
