# ── Bifrost ──────────────────────────────────
# Bifrost Gateway listens on port 8080 by default
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=info
LOG_STYLE=pretty

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_DB=otel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── OpenTelemetry ────────────────────────────
# These are used inside the container - the otel-collector runs on the
# Docker network as "otel-collector", so Bifrost uses that hostname.
OTEL_COLLECTOR_URL=http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
