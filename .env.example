# ── Bifrost ──────────────────────────────────
# Bifrost Gateway listens on port 8080 by default
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=info
LOG_STYLE=pretty

# ── Bifrost UI Auth ─────────────────────────
# Credentials for the Bifrost dashboard (configured via auth_config in config.json)
BIFROST_USERNAME=admin
BIFROST_PASSWORD=bifrost123

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_DB=otel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Provider API Keys ───────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
# Anthropic — routes through Meridian (OAuth), but still needs a key value set
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxx
# GitHub Copilot — https://github.com/settings/tokens (fine-grained, with copilot access)
GITHUB_API_KEY=github_pat_xxxxxxxxxxxxxxxx
# AWS Bedrock — credentials with bedrock:InvokeModel permission
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# ── Headroom ────────────────────────────
# AI Context Compression Proxy
# Listens on port 8787 by default, routes through Bifrost
HEADROOM_PORT=8787
HEADROOM_LOG_LEVEL=info
HEADROOM_TELEMETRY=off
