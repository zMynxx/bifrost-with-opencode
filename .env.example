# ── Bifrost ──────────────────────────────────
# Bifrost Gateway listens on port 8080 by default
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=info
LOG_STYLE=pretty

# ── Bifrost UI Auth ─────────────────────────
# Credentials for the Bifrost dashboard (configured via auth_config in config.json)
BIFROST_USERNAME=admin
BIFROST_PASSWORD=bifrost123

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_DB=otel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Headroom ────────────────────────────
# AI Context Compression Proxy
# Listens on port 8787 by default, routes through Bifrost
HEADROOM_PORT=8787
HEADROOM_LOG_LEVEL=info
HEADROOM_TELEMETRY=off
