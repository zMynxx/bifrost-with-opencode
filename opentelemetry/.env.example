# ── OpenTelemetry Collector ────────────────────
# OTLP receiver endpoints (defaults match otel-collector-config.yaml)
OTLP_GRPC_ENDPOINT=0.0.0.0:4317
OTLP_HTTP_ENDPOINT=0.0.0.0:4318

# ClickHouse connection for telemetry export
CLICKHOUSE_ENDPOINT=tcp://clickhouse:9000
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=otel

# Collector self-monitoring
OTEL_COLLECTOR_HEALTH_ENDPOINT=0.0.0.0:13133
OTEL_COLLECTOR_PPROF_ENDPOINT=0.0.0.0:1777

# Logging & metrics
OTEL_LOG_LEVEL=info
OTEL_METRICS_LEVEL=detailed

# Batch processing
OTEL_BATCH_TIMEOUT=10s
OTEL_BATCH_SEND_SIZE=1000

# Memory limiter
OTEL_MEMORY_LIMIT_MIB=512
OTEL_SPIKE_LIMIT_MIB=128
