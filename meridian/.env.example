# ── Meridian Configuration ──────────────────────
# Proxies Claude Max/Pro OAuth sessions to the Anthropic HTTP API
# so any Anthropic-compatible tool can use your Claude subscription.
#
# Generate a 1-year OAuth token on the host:
#   claude setup-token
# Then paste it below as the oauthToken value in MERIDIAN_PROFILES.

MERIDIAN_PORT=3456
MERIDIAN_HOST=0.0.0.0
NODE_ENV=production

# ── Auth (OAuth token — no volume mount needed) ──
# Run `claude setup-token` on the host, then set this JSON array.
# The token itself is a long-lived sk-ant-oat01-... string.
# MERIDIAN_PROFILES=[{"id":"default","oauthToken":"sk-ant-oat01-..."}]
# MERIDIAN_DEFAULT_PROFILE=default

# Alternative: mount host ~/.claude directory instead of using a token
# (works on Linux where credentials are file-based; on macOS tokens
#  stay in the Keychain and don't carry into Docker via volume mount)
# volumes:
#   - ~/.claude:/home/claude/.claude:ro

# ── Optional tuning ─────────────────────────────
# MERIDIAN_MAX_CONCURRENT=20
# MERIDIAN_LOG_LEVEL=debug
