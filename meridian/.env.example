# ── Meridian Configuration ──────────────────────
# Proxies Claude Max/Pro OAuth sessions to the Anthropic HTTP API
# so any Anthropic-compatible tool can use your Claude subscription.

MERIDIAN_PORT=3456
MERIDIAN_HOST=0.0.0.0
NODE_ENV=production

# Optional: limit concurrent Claude SDK requests
# MERIDIAN_MAX_CONCURRENT=20

# Optional: verbose logging for troubleshooting
# MERIDIAN_LOG_LEVEL=debug
